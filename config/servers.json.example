{
  "defaults": {
    "ssh": {
      "user": "root",
      "port": 22,
      "key": "~/.ssh/id_ed25519"
    }
  },
  "servers": [
    {
      "name": "example-server",
      "host": "192.168.1.10",
      "ssh": {
        "user": "root",
        "port": 22,
        "auth": "key",
        "key": "~/.ssh/id_ed25519"
      },
      "tags": ["web", "production"],
      "enabled": true
    }
  ]
}
